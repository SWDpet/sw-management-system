# 본 파일은 placeholder. 실제 값은 .env 또는 환경변수로 주입.
# .env 는 .gitignore — 절대 commit 금지.
# 자세한 안전 규칙: docs/AGENT_SAFETY.md §4 (시크릿 안전 채널)

# === DB ===
# 실제 prod 좌표는 1Password 또는 사내 운영팀 문의.
# 운영DB(SW_Dept)는 위치별로 네트워크 경로가 다름 (같은 DB, 호스트만 다름):
#   - 사무실      → 사내 내부망 호스트 (INTERNAL_DB_HOST)
#   - 집 / 출장지 → 외부망 호스트     (EXTERNAL_DB_HOST)
# 환경별 접속 규칙 전체: docs/DB_CONNECTION.md
# DB_URL 의 호스트만 위치에 맞게 바꿔 쓰면 됨 (계정/DB/비번 동일).
DB_URL=jdbc:postgresql://YOUR_DB_HOST:YOUR_DB_PORT/SW_Dept
DB_USERNAME=SW_Dept
DB_PASSWORD=YOUR_PASSWORD_HERE

# === LLM ===
OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE_OR_LEAVE_BLANK

# === LLM trace cost 추정 (선택) ===
# codex-trace.sh 가 비용 자동 계산하려면 단가 주입.
# gpt-5 가격 예시 (실제는 OpenAI 페이지에서 확인):
# TRACE_PRICE_PER_1K_INPUT=0.005
# TRACE_PRICE_PER_1K_OUTPUT=0.015
