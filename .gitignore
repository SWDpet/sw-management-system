*.tmp
*.bak
*.swp
*~.nib

# 패키지 파일
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# 로그 파일
logs/
*.log.*

# Node (프론트엔드 사용 시)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Obsidian (팀 공유: 플러그인·테마·단축키. 개인: 창 레이아웃)
# 자세한 동기화 가이드: docs/OBSIDIAN_SETUP.md
docs/.obsidian/workspace.json
docs/.obsidian/workspace-mobile.json
docs/.obsidian/workspace.json.bak
docs/.obsidian/cache
# 개인 일일노트 / 비공개 메모 디렉터리 (필요 시 사용)
docs/_private/
# Obsidian 첫 실행 시 생성된 임시 기본 Vault 흔적 (필요 없으면 수동 삭제)
docs/swbms/

# Refero design references — fetched JSON cache (재생성 가능, 33MB)
docs/design-references/_tmp/json_cache/
docs/design-references/_tmp/__pycache__/

# === 점검내역서 시안D 빌드 산물 (generate.py 출력) ===
# 시안 baseline 인 v5 docx 만 커밋. 중간 버전(v1~v4) 과 미리보기 렌더링은 ignore.
inspection-poc/docs/report-drafts/점검내역서_시안D_annual.docx
inspection-poc/docs/report-drafts/점검내역서_시안D_annual_filled.docx
inspection-poc/docs/report-drafts/점검내역서_시안D_annual_filled_v*.docx
inspection-poc/docs/report-drafts/_v*_p*.png
inspection-poc/docs/report-drafts/_v*_preview.pdf
inspection-poc/docs/report-drafts/_original.hwpx
inspection-poc/docs/report-drafts/_original_text.txt
inspection-poc/docs/report-drafts/_original_extract/
inspection-poc/docs/report-drafts/_extract_text.py
inspection-poc/docs/report-drafts/v3_check.*
inspection-poc/docs/report-drafts/v3_check.files/
inspection-poc/docs/report-drafts/build/

# === inspector agent 런타임 산물 ===
inspection-poc/agent-windows/snapshots/
inspection-poc/agent-windows/out/
inspection-poc/out_unix_encoded/

# === inspector agent 진단 로그 (현장 진단 + 자체 trace) ===
inspection-poc/agent-windows/*.log
inspection-poc/agent-windows/*.trace.log

# === inspector agent 외부 바이너리 (현장 동봉) ===
# tools/README.md 만 commit, 실 exe 는 폐쇄망 반입 절차로 별도 동봉
inspection-poc/agent-windows/tools/*.exe

# === hwpx/docx 분석 일회성 스크래치 (Spring 프로젝트 루트에는 .py 가 없는 게 정상) ===
/*.py
/.scratch/
/Measure.java
/login.html
/login2.html
/sample_texts_*.txt
/schedule_existing_dump.txt

# HTTPS dev keystore (local cert with known password — never commit)
keystore-dev.p12
docs/product-specs/*.png
docs/design-docs/*.png

# 운영데이터 일괄작업 백업 CSV (로컬 보관, 저장소 미포함 — 기관 매핑 등 데이터)
docs/exec-plans/*_backup_*.csv
